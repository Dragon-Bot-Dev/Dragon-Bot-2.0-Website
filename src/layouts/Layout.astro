---
// This MUST be between the triple-dashes
import '../styles/global.css';

interface Props {
	title?: string;
}
const { title = "Dragon Bot 2.0" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/dragon.png" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-950 text-white antialiased">
		<slot />
	</body>
</html>