---
// src/components/CommandCard.astro
const { name, desc } = Astro.props;
---

<div class="command-card p-5 bg-slate-900/50 border border-slate-800 rounded-xl hover:border-orange-500/50 transition-all group relative">
  <div class="flex justify-between items-start mb-2">
    <code class="command-text text-orange-400 font-mono font-bold text-sm group-hover:text-orange-300">
      {name}
    </code>
    
    <button 
      class="copy-btn p-2 rounded-md hover:bg-slate-800 text-slate-500 hover:text-white transition-all active:scale-95"
      data-command={name}
      title="Copy to clipboard"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="check-icon hidden text-green-500"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
  </div>
  
  <p class="text-slate-400 text-sm leading-relaxed">
    {desc}
  </p>
</div>

<script>
  // This script runs in the browser
  const buttons = document.querySelectorAll('.copy-btn');

  buttons.forEach(button => {
    button.addEventListener('click', async () => {
      const command = button.getAttribute('data-command');
      const copyIcon = button.querySelector('.copy-icon');
      const checkIcon = button.querySelector('.check-icon');

      try {
        await navigator.clipboard.writeText(command);
        
        // Visual Feedback Logic
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');

        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy: ', err);
      }
    });
  });
</script>