---
const currentYear = new Date().getFullYear();
const supportServer = "https://discord.gg/RdwtR7HQbr";
const github = "https://github.com/Dragon-Bot-CoC"
---

<footer class="bg-slate-950 border-t border-slate-800 py-12 px-6">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
    
    <div class="space-y-4">
      <div class="flex items-center gap-3">
      
        <span class="font-bold text-lg text-white">Dragon Bot <span class="text-orange-500">2.0</span></span>
      </div>
      <p class="text-slate-500 text-sm leading-relaxed">
        Advanced automation for Clash of Clans communities. Built for reliability, speed, and clan growth.
      </p>
    </div>

    <div class="grid grid-cols-2 gap-8">
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Product</h4>
        <ul class="space-y-2 text-slate-400 text-sm">
          <li><a href="/" class="hover:text-orange-400 transition-colors">Home</a></li>
          <li><a href="/setup" class="hover:text-orange-400 transition-colors">Quick Start</a></li>
          <li><a href="/commands" class="hover:text-orange-400 transition-colors">Commands</a></li>
          
        </ul>
      </div>
      <div>
        <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-4">Support</h4>
        <ul class="space-y-2 text-slate-400 text-sm">
          <li><a href={supportServer} class="hover:text-orange-400 transition-colors">Discord Server</a></li>
          <li><a href={github} class="hover:text-orange-400 transition-colors">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="bg-slate-900/50 p-8 rounded-[2rem] border border-slate-800 backdrop-blur-md relative overflow-hidden group">
  <div class="absolute inset-0 bg-indigo-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

  <div class="relative z-10">
    <div class="flex items-center justify-between mb-8">
      <h4 class="text-white font-black text-xs uppercase tracking-[0.2em]">Live System Health</h4>
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse shadow-[0_0_10px_rgba(34,197,94,0.5)]"></div>
        <span class="text-[10px] font-mono text-green-500 font-bold">ALL SYSTEMS OPERATIONAL</span>
      </div>
    </div>

    <div class="space-y-6">
      <div class="flex justify-between items-end">
        <div class="flex flex-col">
          <span class="text-slate-500 text-[10px] uppercase font-bold tracking-wider mb-1">CoC API Sync</span>
          <span class="text-white text-sm font-semibold">9-Minute Pulse Cycle</span>
        </div>
        <span class="text-indigo-400 font-mono text-xs font-bold px-2 py-1 bg-indigo-500/10 rounded-md tracking-tighter">ACTIVE</span>
      </div>

      <div class="flex justify-between items-end">
        <div class="flex flex-col">
          <span class="text-slate-500 text-[10px] uppercase font-bold tracking-wider mb-1">Cloud Data Integrity</span>
          <span class="text-white text-sm font-semibold">Persistent Clan Storage</span>
        </div>
        <span class="text-indigo-400 font-mono text-xs font-bold px-2 py-1 bg-indigo-500/10 rounded-md tracking-tighter">STABLE</span>
      </div>

      <div class="pt-2">
        <div class="flex justify-between items-center text-[10px] uppercase font-bold tracking-widest mb-3">
          <span class="text-slate-500">API Response Latency</span>
          <span class="text-indigo-400 font-mono font-bold tracking-tighter">42ms</span>
        </div>
        <div class="w-full bg-slate-800/50 h-2 rounded-full overflow-hidden border border-slate-700/50 flex items-center px-1">
          <div class="bg-indigo-500 h-1 w-1/4 rounded-full shadow-[0_0_10px_rgba(99,102,241,0.5)]"></div>
          <div class="h-1 w-3/4 bg-transparent border-l border-slate-700"></div>
        </div>
        <div class="mt-2 text-[8px] text-slate-600 font-bold uppercase tracking-widest flex justify-between">
          <span>Fast</span>
          <span>Slow</span>
        </div>
      </div>
    </div>
  </div>
</div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto mt-12 pt-8 border-t border-slate-900 flex flex-col md:row justify-between items-center gap-4 text-slate-600 text-xs">
    <p>© {currentYear} Dragon Bot. Developed by Keepas.</p>
    <p>All Game Content belongs to Supercell.</p>
  </div>
</footer>