---
// src/components/VideoCard.astro
const { title, description, videoSrc, stepNumber } = Astro.props;
---

<div class="flex flex-col lg:flex-row gap-8 items-center py-12 border-b border-slate-800 last:border-0">
  <div class="w-full lg:w-1/2 aspect-video bg-slate-900 rounded-2xl border border-slate-800 overflow-hidden relative shadow-2xl shadow-orange-500/5 group">
    {videoSrc ? (
      <video 
        src={videoSrc} 
        controls 
        muted 
        loop 
        playsinline 
        class="rounded-xl w-full"
      ></video>
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center space-y-4">
        <div class="w-12 h-12 rounded-full border-2 border-slate-700 border-t-orange-500 animate-spin"></div>
        <p class="text-slate-500 font-mono text-xs uppercase tracking-tighter">Recording Demo: Step {stepNumber}...</p>
      </div>
    )}
    
    <div class="absolute top-4 left-4 bg-orange-600 text-white font-black px-3 py-1 rounded-md text-xs shadow-lg">
      STEP {stepNumber}
    </div>
  </div>

  <div class="w-full lg:w-1/2 space-y-4">
    <h3 class="text-2xl font-bold text-white flex items-center gap-3">
      {title}
    </h3>
    <p class="text-slate-400 leading-relaxed">
      {description}
    </p>
    
    <div class="inline-flex items-center gap-2 px-3 py-1 bg-slate-800 rounded-full text-[10px] font-bold text-slate-500 uppercase">
      <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full"></div>
      
    </div>
  </div>
</div>