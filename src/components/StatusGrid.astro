---
// Mock data - In the future, you can fetch this from your bot's API
const stats = [
  { label: "Servers", value: "142+", icon: "🌐", color: "text-blue-400" },
  { label: "Total Users", value: "12.4k", icon: "👥", color: "text-purple-400" },
  { label: "API Latency", value: "42ms", icon: "⚡", color: "text-green-400" },
  { label: "Uptime", value: "99.9%", icon: "📈", color: "text-orange-400" },
];
---

<div class="w-full max-w-4xl mt-12 grid grid-cols-2 md:grid-cols-4 gap-4 px-4">
  {stats.map((stat) => (
    <div class="bg-slate-900/40 backdrop-blur-md border border-slate-800 p-4 rounded-2xl flex flex-col items-center justify-center transition-all hover:border-slate-600 hover:-translate-y-1">
      <span class="text-xl mb-1">{stat.icon}</span>
      <span class={`text-xl font-black ${stat.color} font-mono`}>{stat.value}</span>
      <span class="text-[10px] uppercase tracking-widest text-slate-500 font-bold">{stat.label}</span>
    </div>
  ))}
</div>