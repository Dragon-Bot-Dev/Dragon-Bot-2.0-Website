---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout title="Support the Evolution | Dragon Bot 2.0">
  <Navbar />
  
  <main class="min-h-screen bg-slate-950 py-24 px-6 relative text-white overflow-hidden selection:bg-indigo-500/30">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[800px] bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-indigo-500/10 via-slate-950 to-slate-950 -z-10"></div>

    <div class="max-w-6xl mx-auto">
      
      <header class="text-center mb-24">
  <div class="inline-block px-4 py-1.5 mb-8 rounded-full border border-indigo-500/30 bg-indigo-500/10 text-indigo-300 text-xs font-bold uppercase tracking-widest">
    Community Funded
  </div>
  
  <h1 class="text-6xl md:text-8xl font-black mb-8 tracking-tighter leading-[0.9] text-white">
    Support the <br/> <span class="text-indigo-400">Evolution.</span>
  </h1>
  
  <div class="flex flex-col items-center gap-8">
    <div class="flex items-baseline gap-2">
      <span class="text-5xl font-black text-white">$2</span>
      <span class="text-slate-400 font-bold uppercase tracking-wider text-sm">/ Monthly Support</span>
    </div>

    <p class="text-slate-400 text-lg max-w-2xl mx-auto font-medium leading-relaxed">
      Dragon Bot 2.0 is just starting out. Your contribution directly covers our hosting and API compute costs. In return, enjoy useful features to help your clan reach the next level.
    </p>
    
    <a href="YOUR_STRIPE_PAYMENT_LINK" 
       class="group relative px-14 py-7 bg-indigo-600 hover:bg-indigo-500 text-white text-2xl font-black rounded-squircle transition-all shadow-2xl shadow-indigo-600/30 hover:-translate-y-1 hover:scale-105 active:scale-95 overflow-hidden flex items-center gap-3">
      <span class="relative z-10">Support & Unlock Pro</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 relative z-10 opacity-70 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
      </svg>
      <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite] transition-transform"></div>
    </a>
    
    <div class="flex items-center gap-4 text-slate-400 font-semibold text-xs tracking-wide">
      <span class="w-12 h-[1px] bg-slate-800"></span>
      <span class="flex items-center gap-2">
        <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1s3.1 1.39 3.1 3.1v2z"/></svg>
        Verified Secure via Stripe
      </span>
      <span class="w-12 h-[1px] bg-slate-800"></span>
    </div>
  </div>
</header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div class="md:col-span-2 p-12 rounded-[3rem] bg-slate-900/60 border border-slate-800 flex flex-col justify-between group hover:border-indigo-500/50 transition-all duration-500 relative overflow-hidden">
          <div class="relative z-10">
            <div class="text-indigo-400 font-mono text-[12px] uppercase tracking-[0.4em] mb-4">Module: Cloud Automation</div>
            <h3 class="text-4xl font-black mb-6 tracking-tight">Store Integration</h3>
            <p class="text-slate-400 text-lg leading-relaxed max-w-md">
              The bot logs into the SuperCell Store to complete weekly missions and redeem your rewards automatically. Never forget your free gems and potions again.
            </p>
          </div>
          <div class="mt-12 flex gap-3 relative z-10">
            <span class="px-4 py-1.5 bg-indigo-500/10 text-indigo-400 text-[10px] font-black rounded-full border border-indigo-500/20 uppercase">API Integrated</span>
            <span class="px-4 py-1.5 bg-slate-800 text-slate-400 text-[10px] font-black rounded-full border border-slate-700 uppercase">100% Syncing</span>
          </div>
          <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-indigo-500/5 blur-[100px] group-hover:bg-indigo-500/10 transition-colors"></div>
        </div>

        <div class="p-10 rounded-[3rem] bg-slate-900/40 border border-slate-800 hover:border-indigo-500/50 transition-all group flex flex-col justify-between">
          <div>
            <div class="text-indigo-400 font-mono text-[12px] uppercase tracking-[0.4em] mb-4">Module: Tactical AI</div>
            <h4 class="text-2xl font-bold mb-4 tracking-tight">Strategy Engine</h4>
            <p class="text-slate-500 text-sm leading-relaxed italic">
              Analyzes opponent's defenses and attacker's equipment alongside the current meta to generate optimized army recommendations for war.
            </p>
          </div>
        </div>

        <div class="p-10 rounded-[3rem] bg-slate-900/40 border border-slate-800 hover:border-emerald-500/50 transition-all">
          <div class="text-emerald-400 font-mono text-[12px] uppercase tracking-[0.4em] mb-4">Module: Analytics</div>
          <h4 class="text-xl font-bold mb-4 tracking-tight">Roster Architect</h4>
          <p class="text-slate-500 text-sm leading-relaxed">
            Utilizing cross-referenced data from previous seasons to generate the optimal roster for upcoming or ongoing CWL matchups.
          </p>
        </div>

        <div class="p-10 rounded-[3rem] bg-slate-900/40 border border-slate-800 hover:border-blue-500/50 transition-all">
          <div class="text-blue-400 font-mono text-[10px] uppercase tracking-[0.3em] mb-4">Module: Database</div>
          <h4 class="text-xl font-bold mb-4 tracking-tight">Historical Archives</h4>
          <p class="text-slate-500 text-sm leading-relaxed">
            Your support covers the storage costs for unlimited historical data retention. View growth patterns and war history without expiration.
          </p>
        </div>

        <div class="p-10 rounded-[3rem] bg-slate-900/40 border border-slate-800 hover:border-rose-500/50 transition-all">
          <div class="text-rose-400 font-mono text-[12px] uppercase tracking-[0.4em] mb-4">Module: Intelligence</div>
          <h4 class="text-xl font-bold mb-4 tracking-tight">Priority Leaks</h4>
          <p class="text-slate-500 text-sm leading-relaxed">
            Zero-latency webhooks for internal game files, official news, and limited-time shop updates streamed to your server instantly.
          </p>
        </div>

      </div>

      <footer class="mt-24 text-center border-t border-slate-900 pt-12">
        <p class="text-slate-600 text-xs italic italic max-w-lg mx-auto leading-relaxed">
          "Dragon Bot 2.0 started as a tool for my own clan. Your support helps me keep the servers running and the code evolving. Thanks for being part of the journey."
        </p>
      </footer>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
</style>