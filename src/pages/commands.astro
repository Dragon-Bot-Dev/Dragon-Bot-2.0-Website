---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CommandCard from '../components/CommandCard.astro'; //
import '../styles/global.css';

const commandGroups = [
  {
    category: "Clan Management",
    icon: "🛡️",
    commands: [
      { name: "/claninfo", desc: "General clan overview" },
      { name: "/clanmembers", desc: "Members ranked by leagues" },
      { name: "/clansearch", desc: "Search for a clan by name" },
      { name: "/capitalraid", desc: "Current Raid Weekend progress" },
      { name: "/previousraids", desc: "History of past Raid seasons" },
      { name: "/currentwar", desc: "Stats & Info for War/CWL" },
      { name: "/warlog", desc: "Check recent war history" },
      { name: "/cwlprep", desc: "Scout matchup levels for current CWL" },
      { name: "/cwlschedule", desc: "View CWL rounds and opponents" },
      { name: "/cwlclansearch", desc: "Search opponent rosters and levels" }
    ]
  },
  {
    category: "Player Tools",
    icon: "⚔️",
    commands: [
      { name: "/playerinfo", desc: "General stats and clan-related info" },
      { name: "/playertroops", desc: "Troop & Siege levels" },
      { name: "/playerequipments", desc: "Hero Equipment progress" },
      { name: "/playerspells", desc: "Spell levels" },
      { name: "/searchmember", desc: "Find a player in your current clan" }
    ]
  },
  {
    category: "Settings & Admin",
    icon: "⚙️",
    commands: [
      { name: "/setclantag", desc: "Link clan and set reminder channels" },
      { name: "/disable_reminders", desc: "Mute War or Raid pings (Admins)" },
      { name: "/botstatus", desc: "View current server config" },
      { name: "/link", desc: "Connect CoC tag to Discord" },
      { name: "/unlink", desc: "Disconnect CoC tag from Discord" }
    ]
  },
  {
    category: "Extras",
    icon: "✨",
    commands: [
      { name: "/flipcoin", desc: "Heads or tails?" },
      { name: "/announce", desc: "Make an announcement with the Dragon Bot" },
      { name: "/receiveposts", desc: "Receive posts from Reddit (default: ClashOfClansLeaks)" },
      { name: "/help", desc: "View the command list in Discord" }
    ]
  }
];
---

<Layout title="Master Commands | Dragon Bot 2.0">
  <Navbar />
  
  <main class="min-h-screen bg-slate-950 py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <header class="mb-16 text-center">
        <h1 class="text-4xl md:text-6xl font-extrabold text-white mb-4">
          Master <span class="text-orange-500">Command</span> List
        </h1>
        <p class="text-slate-400 text-lg max-w-2xl mx-auto">
          Complete documentation for all Dragon Bot 2.0 utilities. 
          Use these in your Discord server to manage your clan like a pro.
        </p>
      </header>

      <div class="grid grid-cols-1 gap-12">
        {commandGroups.map((group) => (
          <section>
            <div class="flex items-center gap-3 mb-6 border-b border-slate-800 pb-2">
              <span class="text-2xl">{group.icon}</span>
              <h2 class="text-2xl font-bold text-white uppercase tracking-wider">
                {group.category}
              </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {group.commands.map((cmd) => (
                <CommandCard name={cmd.name} desc={cmd.desc} />
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>
</Layout>