---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Features from '../components/Features.astro'; 
import CommandCard from '../components/CommandCard.astro';
import Support from '../components/Support.astro';
import StatusGrid from '../components/StatusGrid.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const inviteLink = "https://discord.com/oauth2/authorize?client_id=1322658381974208522&permissions=2147830784&integration_type=0&scope=bot+applications.commands";
---

<Layout title="Dragon Bot 2.0 | Clan Management Evolved">
	<Navbar />

	<main>
		<section class="min-h-screen bg-slate-900 flex flex-col items-center justify-center px-6 py-20 selection:bg-orange-500/30">
			
			
			<div class="text-center max-w-3xl">
				<h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-6">
					Master Your Clan with <br/>
					<span class="bg-gradient-to-r from-orange-400 via-red-500 to-rose-500 bg-clip-text text-transparent">
						Dragon Bot 2.0
					</span>
				</h1>
				
				<p class="text-lg md:text-xl text-slate-400 mb-10 leading-relaxed">
					Stop missing war attacks. Get real-time <span class="text-orange-400 font-semibold">War reminders</span>, 
					manage your individual & clan stats, instant <span class="text-red-400 font-semibold">Reddit leaks</span>
					delivered straight to your Discord server.
				</p>
			</div>

			<div class="flex flex-col items-center w-full">
			<a href={inviteLink} target ="_blank" rel="noopener noreferrer"
			class="w-full sm:w-auto px-12 py-5 bg-indigo-600 hover:bg-indigo-500 text-white text-xl font-black rounded-2xl transition-all shadow-2xl shadow-indigo-500/40 transform hover:-translate-y-1.5 hover:scale-105 active:scale-95 border border-indigo-400/30 flex items-center justify-center gap-3">
			<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515a.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0a12.64 12.64 0 0 0-.617-1.25a.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057a19.9 19.9 0 0 0 5.993 3.03a.078.078 0 0 0 .084-.028a14.09 14.09 0 0 0 1.226-1.994a.076.076 0 0 0-.041-.106a13.107 13.107 0 0 1-1.872-.892a.077.077 0 0 1-.008-.128a10.2 10.2 0 0 0 .372-.292a.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127a12.299 12.299 0 0 1-1.873.892a.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028a19.839 19.839 0 0 0 6.002-3.03a.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.956-2.419 2.157-2.419c1.21 0 2.176 1.086 2.157 2.419c0 1.334-.947 2.419-2.157 2.419zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419c0-1.333.955-2.419 2.157-2.419c1.21 0 2.176 1.086 2.157 2.419c0 1.334-.946 2.419-2.157 2.419z"/></svg>
				Add to Discord
			</a>
			</div>
			
			</div>

			
			<div class="mt-16 pt-8 border-t border-slate-800 w-full max-w-md flex justify-around text-slate-500 font-medium uppercase tracking-widest text-xs">
				<div class="flex items-center gap-2">
					<div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
					9-Min Heartbeat Active
				</div>
				<div>|</div>
				<div>Buffered Response Ready</div>
			</div>
		</section>

		<Support />
		<Features />
		<Footer />
	</main>
</Layout>